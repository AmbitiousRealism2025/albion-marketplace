{
  "permissions": {
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(rm -fr:*)",
      "Bash(/bin/rm -rf:*)",
      "Bash(/usr/bin/rm -rf:*)",
      "Bash(command rm -rf:*)",
      "Bash(sudo rm:*)",
      "Bash(mkfs:*)",
      "Bash(mkfs.*:*)",
      "Bash(dd * of=/dev/:*)",
      "Bash(curl *|bash:*)",
      "Bash(curl *|sh:*)",
      "Bash(wget *|bash:*)",
      "Bash(wget *|sh:*)",
      "Bash(git push --force * main:*)",
      "Bash(git push --force * master:*)",
      "Bash(git push -f * main:*)",
      "Bash(git push -f * master:*)",
      "Bash(chmod -R 777 /:*)",
      "Read(.env)",
      "Read(**/.env)",
      "Read(**/secrets/**)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/*credentials*)",
      "Write(.env)",
      "Write(**/.env)",
      "Write(**/secrets/**)",
      "Write(~/.ssh/**)",
      "Write(~/.aws/**)",
      "Write(**/*.pem)",
      "Write(**/*.key)",
      "Write(**/*credentials*)"
    ]
  }
}
